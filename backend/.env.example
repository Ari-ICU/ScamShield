# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Server port
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/scamshield?schema=public

# JWT secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=<replace_with_64_char_random_hex>
JWT_REFRESH_SECRET=<replace_with_64_char_random_hex>

# Allowed frontend origin (CORS + Socket.IO)
FRONTEND_URL=http://localhost:3000

# Optional: shared secret header for /api/calls/detect webhook
# If set, callers must send header: x-calls-secret: <value>
# Leave blank to allow unauthenticated access (dev only)
CALLS_SECRET=

# Environment
NODE_ENV=development
