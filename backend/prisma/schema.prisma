datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum ScamType {
  BANK_FRAUD
  FAKE_DELIVERY
  INVESTMENT
  LOTTERY
  GOVERNMENT
  ROMANCE
  TECH_SUPPORT
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  CONFIRMED_SCAM
  INSUFFICIENT_EVIDENCE
  FALSE_REPORT
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  role            Role             @default(USER)
  reporterScore   Int              @default(0)
  reports         Report[]
  watchlist       Watchlist[]
  notifications   Notification[]
  reporterProfile ReporterProfile?
  createdAt       DateTime         @default(now())
}

model ReporterProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reputationScore   Int      @default(0)
  approvedReports   Int      @default(0)
  rejectedReports   Int      @default(0)
  verificationLevel String   @default("NEW_USER")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PhoneNumber {
  id          String      @id @default(uuid())
  number      String      @unique
  countryCode String?
  riskScore   Int         @default(0)
  totalReport Int         @default(0)
  reports     Report[]
  appeals     Appeal[]
  watchlists  Watchlist[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([number])
  @@index([riskScore])
  @@index([createdAt])
}

model Report {
  id            String       @id @default(uuid())
  description   String?
  category      ScamType
  status        ReportStatus @default(PENDING)
  userId        String
  numberId      String
  province      String?
  district      String?
  commune       String?
  village       String?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber   PhoneNumber  @relation(fields: [numberId], references: [id], onDelete: Cascade)
  evidence      Evidence[]
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([numberId])
  @@index([status])
  @@index([createdAt])
}

model Evidence {
  id        String   @id @default(uuid())
  fileUrl   String
  fileType  String
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([reportId])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model Appeal {
  id           String       @id @default(uuid())
  numberId     String
  phoneNumber  PhoneNumber  @relation(fields: [numberId], references: [id], onDelete: Cascade)
  reason       String
  proofUrl     String?
  contactEmail String
  status       AppealStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?

  @@index([numberId])
}

model Watchlist {
  id          String      @id @default(uuid())
  userId      String
  numberId    String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber @relation(fields: [numberId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([userId, numberId])
  @@index([userId])
  @@index([numberId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // e.g., "REPORT", "APPEAL", "MODERATION", "WATCHLIST_UPDATE"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

